{
  "rewrites": [
    { "source": "/branch", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/manager", "destination": "/index.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/branch-dashboard", "destination": "/branch-dashboard.html" },
    { "source": "/dashboard-demo", "destination": "/dashboard-demo.html" },
    { "source": "/((?!demo\\.html$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
