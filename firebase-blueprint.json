{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing basic details",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A Simba Supermarket order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "branchId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "items": { "type": "array" },
        "deliveryDetails": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "branchId", "totalAmount", "status", "items", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by users"
    }
  }
}
