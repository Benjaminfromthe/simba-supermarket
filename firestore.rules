rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "benjaminnshimiye633@gmail.com";
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ── Global safety net (deny everything not explicitly allowed) ────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    // Validation: order must have required fields and belong to the requesting user
    function isValidNewOrder(data) {
      return data.keys().hasAll(['userId', 'branchId', 'totalAmount', 'status', 'items', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.totalAmount is number && data.totalAmount >= 0
        && data.status == 'pending'
        && data.items is list && data.items.size() >= 1;
    }

    match /orders/{orderId} {
      // Customer can read their own orders; admin can read all
      allow read:   if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list:   if isSignedIn() && isAdmin();
      // Customer can place a new order
      allow create: if isSignedIn() && isValidNewOrder(incoming());
      // Customer can cancel their own pending orders; admin/staff can update any field
      allow update: if isSignedIn() && (
        existing().userId == request.auth.uid || isAdmin()
      );
    }

    // ── Branch Reviews ────────────────────────────────────────────────────────
    match /branchReviews/{reviewId} {
      allow read: if true;  // public — anyone can read branch ratings
      allow create: if isSignedIn()
        && incoming().keys().hasAll(['branchId', 'userId', 'rating', 'createdAt'])
        && incoming().userId == request.auth.uid
        && incoming().rating is number
        && incoming().rating >= 1
        && incoming().rating <= 5;
      allow update, delete: if isSignedIn()
        && (existing().userId == request.auth.uid || isAdmin());
    }

    // ── Inventory ─────────────────────────────────────────────────────────────
    // Any signed-in user can read stock (for "check stock at branch")
    // Writes allowed for signed-in users (stock decrements on order + staff updates)
    match /inventory/{invId} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    // ── No-show flags ─────────────────────────────────────────────────────────
    match /noshow_flags/{userId} {
      allow read:  if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn();   // staff flags customers; admin manages
    }
  }
}
